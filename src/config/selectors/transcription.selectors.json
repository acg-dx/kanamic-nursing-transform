{
  "version": "1.0.0",
  "workflow": "transcription",
  "lastUpdated": "2026-02-25",
  "selectors": {
    "login_username": {
      "id": "login_username",
      "description": "ログインユーザー名入力",
      "primary": "#username",
      "fallbacks": ["input[name='username']", "input[type='text']:first-of-type"],
      "context": "ログインページのユーザー名入力フィールド"
    },
    "login_password": {
      "id": "login_password",
      "description": "ログインパスワード入力",
      "primary": "#password",
      "fallbacks": ["input[name='password']", "input[type='password']"],
      "context": "ログインページのパスワード入力フィールド"
    },
    "login_submit": {
      "id": "login_submit",
      "description": "ログインボタン",
      "primary": "button[type='submit']",
      "fallbacks": ["input[type='submit']", ".login-btn", "button:has-text('ログイン')"],
      "context": "ログインフォームの送信ボタン"
    },
    "main_dashboard": {
      "id": "main_dashboard",
      "description": "メインダッシュボード（ログイン成功確認）",
      "primary": ".main-content",
      "fallbacks": ["#main", ".dashboard", "nav.main-nav"],
      "context": "ログイン後のメインダッシュボード要素"
    },
    "menu_results": {
      "id": "menu_results",
      "description": "実績入力メニュー",
      "primary": "a[href*='results']",
      "fallbacks": ["a:has-text('実績')", ".menu-item:has-text('実績')"],
      "context": "メニューバーの実績入力リンク"
    },
    "search_patient_name": {
      "id": "search_patient_name",
      "description": "患者名検索入力",
      "primary": "#patient-search",
      "fallbacks": ["input[name='patientName']", "input[placeholder*='利用者']"],
      "context": "患者名を検索するための入力フィールド"
    },
    "search_button": {
      "id": "search_button",
      "description": "検索ボタン",
      "primary": "button.search-btn",
      "fallbacks": ["button:has-text('検索')", "input[type='submit'][value='検索']"],
      "context": "検索フォームの実行ボタン"
    },
    "patient_list_names": {
      "id": "patient_list_names",
      "description": "患者一覧の名前リスト",
      "primary": "table.patient-list td.name",
      "fallbacks": [".patient-row .name", "tr.patient td:first-child"],
      "context": "検索結果の患者名リスト"
    },
    "service_type1_select": {
      "id": "service_type1_select",
      "description": "支援区分1選択（医療/介護）",
      "primary": "select#serviceType1",
      "fallbacks": ["select[name='serviceType1']", "select.service-type-1"],
      "context": "医療・介護の区分を選択するセレクトボックス"
    },
    "service_type2_select": {
      "id": "service_type2_select",
      "description": "支援区分2選択（通常/リハビリ等）",
      "primary": "select#serviceType2",
      "fallbacks": ["select[name='serviceType2']", "select.service-type-2"],
      "context": "通常・リハビリ等の詳細区分を選択するセレクトボックス"
    },
    "start_time_input": {
      "id": "start_time_input",
      "description": "開始時刻入力",
      "primary": "input#startTime",
      "fallbacks": ["input[name='startTime']", "input.start-time"],
      "context": "サービス開始時刻を入力するフィールド"
    },
    "end_time_input": {
      "id": "end_time_input",
      "description": "終了時刻入力",
      "primary": "input#endTime",
      "fallbacks": ["input[name='endTime']", "input.end-time"],
      "context": "サービス終了時刻を入力するフィールド"
    },
    "staff_name_input": {
      "id": "staff_name_input",
      "description": "担当者名入力",
      "primary": "input#staffName",
      "fallbacks": ["input[name='staffName']", "input.staff-name"],
      "context": "担当スタッフ名を入力するフィールド"
    },
    "accompany_checkbox": {
      "id": "accompany_checkbox",
      "description": "同行チェックボックス",
      "primary": "input#accompany",
      "fallbacks": ["input[name='accompany']", "input[type='checkbox'].accompany"],
      "context": "同行サービスの有無を示すチェックボックス"
    },
    "accompany_clerk_checkbox": {
      "id": "accompany_clerk_checkbox",
      "description": "同行事務員チェックボックス",
      "primary": "input#accompanyClerk",
      "fallbacks": ["input[name='accompanyClerk']", "input[type='checkbox'].accompany-clerk"],
      "context": "事務員が同行する場合のチェックボックス"
    },
    "emergency_clerk_checkbox": {
      "id": "emergency_clerk_checkbox",
      "description": "緊急時事務員チェックボックス",
      "primary": "input#emergencyClerk",
      "fallbacks": ["input[name='emergencyClerk']", "input[type='checkbox'].emergency-clerk"],
      "context": "緊急時に事務員が対応する場合のチェックボックス"
    },
    "multiple_visit_checkbox": {
      "id": "multiple_visit_checkbox",
      "description": "複数名訪問チェックボックス",
      "primary": "input#multipleVisit",
      "fallbacks": ["input[name='multipleVisit']", "input[type='checkbox'].multiple-visit"],
      "context": "複数のスタッフが訪問する場合のチェックボックス"
    },
    "save_button": {
      "id": "save_button",
      "description": "保存ボタン",
      "primary": "button#save",
      "fallbacks": ["button[type='submit'].save", "button:has-text('保存')", "input[value='保存']"],
      "context": "入力内容を保存するボタン"
    },
    "save_success_indicator": {
      "id": "save_success_indicator",
      "description": "保存成功インジケーター",
      "primary": ".success-message",
      "fallbacks": [".alert-success", "div:has-text('保存しました')"],
      "context": "保存が成功したことを示すメッセージ"
    },
    "error_message": {
      "id": "error_message",
      "description": "エラーメッセージ",
      "primary": ".error-message",
      "fallbacks": [".alert-danger", ".alert-error", "div.error"],
      "context": "エラーが発生した際に表示されるメッセージ"
    }
  }
}
